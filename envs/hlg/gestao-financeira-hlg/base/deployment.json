{
  "apiVersion": "apps/v1",
  "kind": "Deployment",
  "metadata": {
    "annotations": {
      "meta.helm.sh/release-name": "gestao-hlg",
      "meta.helm.sh/release-namespace": "gestao-financeira-hlg"
    },
    "labels": {
      "app": "gestao-hlg-gestao-financeira",
      "app.kubernetes.io/instance": "gestao-hlg",
      "app.kubernetes.io/managed-by": "Helm",
      "app.kubernetes.io/name": "gestao-financeira",
      "helm.sh/chart": "gestao-financeira-0.1.0"
    },
    "name": "gestao-hlg-gestao-financeira",
    "namespace": "gestao-financeira-hlg"
  },
  "spec": {
    "progressDeadlineSeconds": 600,
    "replicas": 1,
    "revisionHistoryLimit": 10,
    "selector": {
      "matchLabels": {
        "app.kubernetes.io/component": "application",
        "app.kubernetes.io/instance": "gestao-hlg",
        "app.kubernetes.io/name": "gestao-financeira"
      }
    },
    "strategy": {
      "rollingUpdate": {
        "maxSurge": "25%",
        "maxUnavailable": "25%"
      },
      "type": "RollingUpdate"
    },
    "template": {
      "metadata": {
        "annotations": {
          "kubectl.kubernetes.io/restartedAt": "2026-01-07T15:23:48.434Z"
        },
        "labels": {
          "app": "gestao-hlg-gestao-financeira",
          "app.kubernetes.io/component": "application",
          "app.kubernetes.io/instance": "gestao-hlg",
          "app.kubernetes.io/name": "gestao-financeira"
        }
      },
      "spec": {
        "containers": [
          {
            "env": [
              {
                "name": "NODE_ENV",
                "value": "production"
              },
              {
                "name": "SESSION_COOKIE_SECURE",
                "value": "false"
              },
              {
                "name": "DB_HOST",
                "value": "gestao-hlg-gestao-financeira-db"
              },
              {
                "name": "DB_PORT",
                "value": "%!d(float64=3306)"
              },
              {
                "name": "DB_NAME",
                "valueFrom": {
                  "secretKeyRef": {
                    "key": "MARIADB_DATABASE",
                    "name": "gestao-hlg-gestao-financeira-db"
                  }
                }
              },
              {
                "name": "DB_USER",
                "valueFrom": {
                  "secretKeyRef": {
                    "key": "MARIADB_USER",
                    "name": "gestao-hlg-gestao-financeira-db"
                  }
                }
              },
              {
                "name": "DB_PASSWORD",
                "valueFrom": {
                  "secretKeyRef": {
                    "key": "MARIADB_PASSWORD",
                    "name": "gestao-hlg-gestao-financeira-db"
                  }
                }
              }
            ],
            "image": "gestao-financeira-hlg:latest",
            "imagePullPolicy": "IfNotPresent",
            "livenessProbe": {
              "failureThreshold": 3,
              "httpGet": {
                "path": "/",
                "port": 3000,
                "scheme": "HTTP"
              },
              "initialDelaySeconds": 15,
              "periodSeconds": 20,
              "successThreshold": 1,
              "timeoutSeconds": 1
            },
            "name": "gestao-financeira",
            "ports": [
              {
                "containerPort": 3000,
                "protocol": "TCP"
              }
            ],
            "readinessProbe": {
              "failureThreshold": 3,
              "httpGet": {
                "path": "/",
                "port": 3000,
                "scheme": "HTTP"
              },
              "initialDelaySeconds": 5,
              "periodSeconds": 10,
              "successThreshold": 1,
              "timeoutSeconds": 1
            },
            "resources": {},
            "terminationMessagePath": "/dev/termination-log",
            "terminationMessagePolicy": "File"
          }
        ],
        "dnsPolicy": "ClusterFirst",
        "restartPolicy": "Always",
        "schedulerName": "default-scheduler",
        "securityContext": {},
        "terminationGracePeriodSeconds": 30
      }
    }
  }
}
