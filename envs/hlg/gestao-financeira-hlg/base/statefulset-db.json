{
  "apiVersion": "apps/v1",
  "kind": "StatefulSet",
  "metadata": {
    "annotations": {
      "meta.helm.sh/release-name": "gestao-hlg",
      "meta.helm.sh/release-namespace": "gestao-financeira-hlg"
    },
    "labels": {
      "app.kubernetes.io/component": "database",
      "app.kubernetes.io/instance": "gestao-hlg",
      "app.kubernetes.io/managed-by": "Helm",
      "app.kubernetes.io/name": "gestao-financeira",
      "helm.sh/chart": "gestao-financeira-0.1.0"
    },
    "name": "gestao-hlg-gestao-financeira-db",
    "namespace": "gestao-financeira-hlg"
  },
  "spec": {
    "persistentVolumeClaimRetentionPolicy": {
      "whenDeleted": "Retain",
      "whenScaled": "Retain"
    },
    "podManagementPolicy": "OrderedReady",
    "replicas": 1,
    "revisionHistoryLimit": 10,
    "selector": {
      "matchLabels": {
        "app.kubernetes.io/component": "database",
        "app.kubernetes.io/instance": "gestao-hlg",
        "app.kubernetes.io/name": "gestao-financeira"
      }
    },
    "serviceName": "gestao-hlg-gestao-financeira-db",
    "template": {
      "metadata": {
        "labels": {
          "app.kubernetes.io/component": "database",
          "app.kubernetes.io/instance": "gestao-hlg",
          "app.kubernetes.io/name": "gestao-financeira"
        }
      },
      "spec": {
        "containers": [
          {
            "env": [
              {
                "name": "MARIADB_ROOT_PASSWORD",
                "valueFrom": {
                  "secretKeyRef": {
                    "key": "MARIADB_ROOT_PASSWORD",
                    "name": "gestao-hlg-gestao-financeira-db"
                  }
                }
              },
              {
                "name": "MARIADB_DATABASE",
                "valueFrom": {
                  "secretKeyRef": {
                    "key": "MARIADB_DATABASE",
                    "name": "gestao-hlg-gestao-financeira-db"
                  }
                }
              },
              {
                "name": "MARIADB_USER",
                "valueFrom": {
                  "secretKeyRef": {
                    "key": "MARIADB_USER",
                    "name": "gestao-hlg-gestao-financeira-db"
                  }
                }
              },
              {
                "name": "MARIADB_PASSWORD",
                "valueFrom": {
                  "secretKeyRef": {
                    "key": "MARIADB_PASSWORD",
                    "name": "gestao-hlg-gestao-financeira-db"
                  }
                }
              }
            ],
            "image": "mariadb:11.4",
            "imagePullPolicy": "IfNotPresent",
            "name": "mariadb",
            "ports": [
              {
                "containerPort": 3306,
                "name": "mysql",
                "protocol": "TCP"
              }
            ],
            "resources": {
              "limits": {
                "cpu": "500m",
                "memory": "512Mi"
              },
              "requests": {
                "cpu": "100m",
                "memory": "256Mi"
              }
            },
            "terminationMessagePath": "/dev/termination-log",
            "terminationMessagePolicy": "File",
            "volumeMounts": [
              {
                "mountPath": "/var/lib/mysql",
                "name": "data"
              }
            ]
          }
        ],
        "dnsPolicy": "ClusterFirst",
        "restartPolicy": "Always",
        "schedulerName": "default-scheduler",
        "securityContext": {},
        "terminationGracePeriodSeconds": 30
      }
    },
    "updateStrategy": {
      "rollingUpdate": {
        "partition": 0
      },
      "type": "RollingUpdate"
    },
    "volumeClaimTemplates": [
      {
        "apiVersion": "v1",
        "kind": "PersistentVolumeClaim",
        "metadata": {
          "name": "data"
        },
        "spec": {
          "accessModes": [
            "ReadWriteOnce"
          ],
          "resources": {
            "requests": {
              "storage": "5Gi"
            }
          },
          "volumeMode": "Filesystem"
        },
        "status": {
          "phase": "Pending"
        }
      }
    ]
  }
}
