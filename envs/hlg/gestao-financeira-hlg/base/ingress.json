{
  "apiVersion": "networking.k8s.io/v1",
  "kind": "Ingress",
  "metadata": {
    "annotations": {
      "kubernetes.io/ingress.class": "nginx",
      "meta.helm.sh/release-name": "gestao-hlg",
      "meta.helm.sh/release-namespace": "gestao-financeira-hlg"
    },
    "labels": {
      "app.kubernetes.io/component": "application",
      "app.kubernetes.io/instance": "gestao-hlg",
      "app.kubernetes.io/managed-by": "Helm",
      "app.kubernetes.io/name": "gestao-financeira",
      "helm.sh/chart": "gestao-financeira-0.1.0"
    },
    "name": "gestao-hlg-gestao-financeira",
    "namespace": "gestao-financeira-hlg"
  },
  "spec": {
    "ingressClassName": "nginx",
    "rules": [
      {
        "host": "finan-hlg.jgpjunior.online",
        "http": {
          "paths": [
            {
              "backend": {
                "service": {
                  "name": "gestao-hlg-gestao-financeira",
                  "port": {
                    "number": 80
                  }
                }
              },
              "path": "/",
              "pathType": "Prefix"
            }
          ]
        }
      }
    ]
  }
}
