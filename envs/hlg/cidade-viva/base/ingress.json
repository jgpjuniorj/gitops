{
  "apiVersion": "networking.k8s.io/v1",
  "kind": "Ingress",
  "metadata": {
    "annotations": {
      "cloudflare-tunnel.ingress.kubernetes.io/origin-server-name": "cidade-viva-web.cidade-viva.svc.cluster.local",
      "cloudflare-tunnel.ingress.kubernetes.io/proxied": "true",
      "cloudflare-tunnel.ingress.kubernetes.io/warp-routing-enabled": "true",
      "external-dns.alpha.kubernetes.io/hostname": "cidade-viva.example.com",
      "external-dns.alpha.kubernetes.io/ttl": "60"
    },
    "labels": {
      "app.kubernetes.io/component": "web",
      "app.kubernetes.io/managed-by": "kustomize",
      "app.kubernetes.io/name": "cidade-viva",
      "app.kubernetes.io/part-of": "cidade-viva"
    },
    "name": "cidade-viva-web",
    "namespace": "cidade-viva"
  },
  "spec": {
    "ingressClassName": "cloudflare-tunnel",
    "rules": [
      {
        "host": "cidade-viva.example.com",
        "http": {
          "paths": [
            {
              "backend": {
                "service": {
                  "name": "cidade-viva-web",
                  "port": {
                    "name": "http"
                  }
                }
              },
              "path": "/",
              "pathType": "Prefix"
            }
          ]
        }
      },
      {
        "host": "cidade-viva-web.cidade-viva.svc.cluster.local",
        "http": {
          "paths": [
            {
              "backend": {
                "service": {
                  "name": "cidade-viva-web",
                  "port": {
                    "name": "http"
                  }
                }
              },
              "path": "/",
              "pathType": "Prefix"
            }
          ]
        }
      }
    ]
  }
}
