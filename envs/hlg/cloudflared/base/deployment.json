{
  "apiVersion": "apps/v1",
  "kind": "Deployment",
  "metadata": {
    "name": "cloudflared",
    "namespace": "cloudflared"
  },
  "spec": {
    "progressDeadlineSeconds": 600,
    "replicas": 1,
    "revisionHistoryLimit": 10,
    "selector": {
      "matchLabels": {
        "app": "cloudflared"
      }
    },
    "strategy": {
      "rollingUpdate": {
        "maxSurge": "25%",
        "maxUnavailable": "25%"
      },
      "type": "RollingUpdate"
    },
    "template": {
      "metadata": {
        "annotations": {
          "kubectl.kubernetes.io/restartedAt": "2026-02-26T00:00:00-03:00"
        },
        "labels": {
          "app": "cloudflared"
        }
      },
      "spec": {
        "containers": [
          {
            "args": [
              "tunnel",
              "--config",
              "/etc/cloudflared/config.yml",
              "run"
            ],
            "image": "cloudflare/cloudflared:latest",
            "imagePullPolicy": "Always",
            "name": "cloudflared",
            "resources": {},
            "terminationMessagePath": "/dev/termination-log",
            "terminationMessagePolicy": "File",
            "volumeMounts": [
              {
                "mountPath": "/etc/cloudflared",
                "name": "config"
              },
              {
                "mountPath": "/etc/cloudflared/creds",
                "name": "creds"
              }
            ]
          }
        ],
        "dnsPolicy": "ClusterFirst",
        "restartPolicy": "Always",
        "schedulerName": "default-scheduler",
        "securityContext": {},
        "terminationGracePeriodSeconds": 30,
        "volumes": [
          {
            "configMap": {
              "defaultMode": 420,
              "name": "cloudflared-config"
            },
            "name": "config"
          },
          {
            "name": "creds",
            "secret": {
              "defaultMode": 420,
              "secretName": "tunnel-credentials"
            }
          }
        ]
      }
    }
  }
}
